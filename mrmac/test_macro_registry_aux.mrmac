$MACRO_FILE AuxTest;

$MACRO Child;
DEF_INT(P);
SET_GLOBAL_INT('Seen', 1);
P := PARSE_INT('/P=', MPARM_STR);
RETURN_INT := P;
RETURN_STR := 'child:' + MPARM_STR + ':' + STR(FIRST_RUN);
END_MACRO;

$MACRO Other;
DEF_INT(P);
P := PARSE_INT('/P=', MPARM_STR);
RETURN_INT := P + GLOBAL_INT('Seen');
RETURN_STR := 'other:' + MPARM_STR + ':' + STR(FIRST_RUN);
END_MACRO;
