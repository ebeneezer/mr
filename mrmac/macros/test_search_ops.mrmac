$MACRO SearchOps;
DEF_INT(FoundBack, FoundFwd);
DEF_STR(Needle, Replacement);

Needle := 'theme';
Replacement := 'palette';
IGNORE_CASE := TRUE;
FoundFwd := SEARCH_FWD(Needle, 0);
IF FoundFwd THEN
    REPLACE(Replacement);
END;
FoundBack := SEARCH_BWD(Replacement, 0);
TVCALL MessageBox('F=' + STR(FoundFwd) + ' B=' + STR(FoundBack));
END_MACRO;
