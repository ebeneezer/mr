$MACRO Chapter23ScreenOpsProbe FROM EDIT;
DEF_INT(W, H, X, Y);
DEF_STR(StatusText);

MAKE_MESSAGE('STEP 01: SCREEN_WIDTH + SCREEN_LENGTH');
W := SCREEN_WIDTH;
H := SCREEN_LENGTH;
DELAY(2500);

MAKE_MESSAGE('STEP 02: CLEAR_SCREEN + PUT_BOX');
CLEAR_SCREEN;
PUT_BOX(2, 2, W - 1, H - 2, 1, 15, 'CH23 SCREEN OPS', 1);
DELAY(2500);

MAKE_MESSAGE('STEP 03: WRITE');
WRITE('SCREEN ' + STR(W) + 'x' + STR(H), 4, 4, 1, 14);
DELAY(2500);

MAKE_MESSAGE('STEP 04: GOTOXY + WHEREX + WHEREY');
GOTOXY(10, 8);
X := WHEREX;
Y := WHEREY;
WRITE('CURSOR ' + STR(X) + ',' + STR(Y), 4, 6, 1, 14);
DELAY(2500);

MAKE_MESSAGE('STEP 05: CLR_LINE');
GOTOXY(4, 8);
WRITE('Diese Zeile wird gleich geloescht', 4, 8, 1, 12);
DELAY(2500);
GOTOXY(4, 8);
CLR_LINE;
DELAY(2500);

MAKE_MESSAGE('STEP 06: PUT_LINE_NUM + PUT_COL_NUM');
PUT_LINE_NUM(12);
PUT_COL_NUM(34);
DELAY(2500);

MAKE_MESSAGE('STEP 07: SCROLL_BOX_UP');
WRITE('Scroll Demo A', 6, 10, 1, 11);
WRITE('Scroll Demo B', 6, 11, 1, 11);
WRITE('Scroll Demo C', 6, 12, 1, 11);
DELAY(1500);
SCROLL_BOX_UP(3, 3, W - 2, H - 3, 30);
DELAY(2500);

MAKE_MESSAGE('STEP 08: SCROLL_BOX_DN');
SCROLL_BOX_DN(3, 3, W - 2, H - 3, 30);
DELAY(2500);

MAKE_MESSAGE('STEP 09: MAKE_MESSAGE (normal)');
DELAY(2500);

MAKE_MESSAGE('STEP 10: WORKING (warning)');
WORKING;
DELAY(2500);

MAKE_MESSAGE('STEP 11: BRAIN(1)');
BRAIN(1);
DELAY(2500);

MAKE_MESSAGE('STEP 12: BRAIN(0)');
BRAIN(0);
DELAY(2500);

StatusText := 'WHEREX=' + STR(WHEREX) + ' WHEREY=' + STR(WHEREY);
MAKE_MESSAGE(StatusText);
DELAY(3000);

CLEAR_SCREEN;
MARQUEE('');
END_MACRO;
