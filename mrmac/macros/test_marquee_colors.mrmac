$MACRO MarqueeColorProbe FROM EDIT;
DEF_STR(ShortInfo, ShortWarn, ShortErr);
DEF_STR(LongInfo, LongWarn, LongErr);

ShortInfo := 'normal short';
ShortWarn := 'warning short';
ShortErr := 'error short';

LongInfo := 'N1234567890 1234567890 1234567890 1234567890 1234567890 1234567890 1234567890 123456789 N1234567890 1234567890 1234567890 1234567890 1234567890 1234567890 1234567890 123456789';
LongWarn := 'W1234567890 1234567890 1234567890 1234567890 1234567890 1234567890 1234567890 123456789 W1234567890 1234567890 1234567890 1234567890 1234567890 1234567890 1234567890 123456789';
LongErr := 'E1234567890 1234567890 1234567890 1234567890 1234567890 1234567890 1234567890 123456789 E1234567890 1234567890 1234567890 1234567890 1234567890 1234567890 1234567890 123456789';

MARQUEE(ShortInfo);
DELAY(10000);

MARQUEE_WARNING(ShortWarn);
DELAY(10000);

MARQUEE_ERROR(ShortErr);
DELAY(10000);

MARQUEE(LongInfo);
DELAY(10000);

MARQUEE_WARNING(LongWarn);
DELAY(10000);

MARQUEE_ERROR(LongErr);
DELAY(10000);

MARQUEE('');
END_MACRO;
