$MACRO TESTENV;
DEF_STR(SHELLPATH, SHELLVER, APPPATH, P0, P1, HOMEVAL);
DEF_INT(ARGC, CPUCODE);

SHELLPATH := COMSPEC;
SHELLVER := OS_VERSION;
APPPATH := MR_PATH;
P0 := PARAM_STR(0);
P1 := PARAM_STR(1);
HOMEVAL := GET_ENVIRONMENT('HOME');
ARGC := PARAM_COUNT;
CPUCODE := CPU;

SET_GLOBAL_STR('SHELLPATH', SHELLPATH);
SET_GLOBAL_STR('SHELLVER', SHELLVER);
SET_GLOBAL_STR('APPPATH', APPPATH);
SET_GLOBAL_STR('P0', P0);
SET_GLOBAL_STR('P1', P1);
SET_GLOBAL_STR('HOMEVAL', HOMEVAL);
SET_GLOBAL_INT('ARGC', ARGC);
SET_GLOBAL_INT('CPUCODE', CPUCODE);
END_MACRO;

$MACRO TESTOSIO;
CHANGE_DIR(MR_PATH);
SET_GLOBAL_INT('CDERR', ERROR_LEVEL);
END_MACRO;
