{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "mrmac",
      "camelcase": "MRMAC",
      "scope": "source.mrmac",
      "path": ".",
      "file-types": [
        "mrmac"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "MRMAC grammar for tree-sitter",
    "authors": [
      {
        "name": "Codex"
      }
    ]
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
