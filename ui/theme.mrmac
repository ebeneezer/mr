$MACRO InitTheme;
    { Test der Symboltabelle und Variablen-Deklaration }
    DEF_INT(X, Y, Z);
    DEF_STR(FileName, Extension);
    DEF_CHAR(Key);
    DEF_REAL(ScaleFactor);

    { Visuelles Feedback: Roter Rahmen, um Ausfuehrung zu bestaetigen }
    TVCALL RegisterTheme (
        $4F, $4F, $4F, $4F, $4F, $4F, $4F, $4F, 
        $1F, $1E, $1A, $1B, $1C, $30, $1F, $1F, 
        'Default'
    );
END_MACRO;