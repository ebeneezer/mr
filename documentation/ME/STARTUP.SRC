{******************************************************************************}
{                                MULTI-EDIT MACRO                              }
{                                                                              }
{Name: KAL                                   Timestamp: 06/04/88 02:46pm       }
{                                                                              }
{Description: Shows calander on screen       Contributed by Dick Botbyl        }
{                                                                              }
{******************************************************************************}

$macro kal dump;

  def_str(cal_top,cal_day,cal_bar,cal_inp,
          cal_lin,cal_lli,cal_mon,cal_bot,
          mon_str,day_str,year_str,long_mo,
          sho_day_str,cal_key);
  def_int(mon_num,day_o_wk,short_yr,temp_value,num_days,start_day,mon_type,
          long_yr,strt_ln,sho_day,Key_code,start_day_out);



  cal_top := '│                                  ║';
  cal_day := '│ Mon  Tue  Wed  Thu  Fri  Sat Sun ║';
  cal_bar := 'Ų════č════č════č════č════č════č════╣';
  cal_inp := '│    │    │    │    │    │    │    ║';
  cal_lin := '├────┼────┼────┼────┼────┼────┼────Č';
  cal_lli := '├────┼────┼────┴────┴────┴────┴────Č';
  cal_mon := '│    │    │                        ║';
  cal_bot := 'Ų════Ž════Ž════════════════════════╣';
  cal_key := '│   Months    Years     [End]';
  mon_str  := COPY (DATE,1,2);
  day_str  := COPY (DATE,4,2);
  year_str := COPY (DATE,7,2);



  IF VAL(temp_value, mon_str)  = 0 then
    mon_num := temp_value;
  END;
  IF VAL(temp_value, day_str)  = 0 then
    day_o_wk := temp_value;
  END;
  IF VAL(temp_value, year_str) = 0 then
    short_yr := temp_value;
  END;
  long_yr := short_yr + 1900;



  put_box(21,4,58,22,lightgray,back_color,'Calendar',TRUE);

BEGIN_TO:
  write(cal_top,21, 5,lightgray,back_color);
  write(cal_day,21, 6,lightgray,back_color);
  write(cal_bar,21, 7,lightgray,back_color);
  write(cal_inp,21, 8,lightgray,back_color);
  write(cal_lin,21, 9,lightgray,back_color);
  write(cal_inp,21,10,lightgray,back_color);
  write(cal_lin,21,11,lightgray,back_color);
  write(cal_inp,21,12,lightgray,back_color);
  write(cal_lin,21,13,lightgray,back_color);
  write(cal_inp,21,14,lightgray,back_color);
  write(cal_lin,21,15,lightgray,back_color);
  write(cal_inp,21,16,lightgray,back_color);
  write(cal_lli,21,17,lightgray,back_color);
  write(cal_mon,21,18,lightgray,back_color);
  write(cal_bot,21,19,lightgray,back_color);
  write(cal_key,21,20,lightgray,back_color);

  IF short_yr < 72 THEN
    short_yr := short_yr +28;
  END;
  IF short_yr > 99 THEN
    short_yr := short_yr -28;
  END;

  IF short_yr = 72 THEN
    mon_type :=  13;
  END;
  IF short_yr = 73 THEN
    mon_type :=   1;
  END;
  IF short_yr = 74 THEN
    mon_type :=   2;
  END;
  IF short_yr = 75 THEN
    mon_type :=   3;
  END;
  IF short_yr = 76 THEN
    mon_type :=  11;
  END;
  IF short_yr = 77 THEN
    mon_type :=   7;
  END;
  IF short_yr = 78 THEN
    mon_type :=   8;
  END;
  IF short_yr = 79 THEN
    mon_type :=   1;
  END;
  IF short_yr = 80 THEN
    mon_type :=  09;
  END;
  IF short_yr = 81 THEN
    mon_type :=   4;
  END;
  IF short_yr = 82 THEN
    mon_type :=   5;
  END;
  IF short_yr = 83 THEN
    mon_type :=   6;
  END;
  IF short_yr = 84 THEN
    mon_type :=  14;
  END;
  IF short_yr = 85 THEN
    mon_type :=   2;
  END;
  IF short_yr = 86 THEN
    mon_type :=   3;
  END;
  IF short_yr = 87 THEN
    mon_type :=   4;
  END;
  IF short_yr = 88 THEN
    mon_type :=  12;
  END;
  IF short_yr = 89 THEN
    mon_type :=   7;
  END;
  IF short_yr = 90 THEN
    mon_type :=   1;
  END;
  IF short_yr = 91 THEN
    mon_type :=   2;
  END;
  IF short_yr = 92 THEN
    mon_type :=  10;
  END;
  IF short_yr = 93 THEN
    mon_type :=   5;
  END;
  IF short_yr = 94 THEN
    mon_type :=   6;
  END;
  IF short_yr = 95 THEN
    mon_type :=   7;
  END;
  IF short_yr = 96 THEN
    mon_type :=  08;
  END;
  IF short_yr = 97 THEN
    mon_type :=   3;
  END;
  IF short_yr = 98 THEN
    mon_type :=   4;
  END;
  IF short_yr = 99 THEN
    mon_type :=   5;
  END;
  num_days := 31;
  IF mon_num = 1 THEN
    mon_str := 'January';
    start_day := 1;
  END;
  IF mon_num = 2 THEN
    start_day := 4;
    num_days := 28;
    mon_str := 'February';
  END;
  IF mon_num = 3 THEN
    mon_str := 'March';
    start_day := 4;
  END;
  IF mon_num = 4 THEN
    num_days := 30;
    mon_str := 'April';
    start_day := 7;
  END;
  IF mon_num = 5 THEN
    mon_str := 'May';
    start_day := 2;
  END;
  IF mon_num = 6 THEN
    num_days := 30;
    mon_str := 'June';
    start_day := 5;
  END;
  IF mon_num = 7 THEN
    mon_str := 'July';
    start_day := 7;
  END;
  IF mon_num = 8 THEN
    mon_str := 'August';
    start_day := 3;
  END;
  IF mon_num = 9 THEN
    num_days := 30;
    mon_str := 'September';
    start_day := 6;
  END;
  IF mon_num = 10 THEN
    mon_str := 'October';
    start_day := 1;
  END;
  IF mon_num =11 THEN
    num_days := 30;
    mon_str := 'November';
    start_day := 4;
  END;
  IF mon_num =12 THEN
    mon_str := 'December';
    start_day := 6;
  END;

  IF mon_type > 7 then
    IF mon_num > 2 THEN
      start_day := start_day + 1;
    END;
  END;
  IF mon_type > 7 THEN
    mon_type := mon_type -7;
  END;
  start_day := start_day + mon_type - 1;
  IF start_day > 7 THEN
    start_day := start_day - 7;
  END;


  write(mon_str,38,18,lightgray,darkgray);
  write(STR(long_yr),49,18,lightgray,darkgray);

  strt_ln := 8;
  sho_day := 1;
  start_day_out := (start_day * 5) + 18;
  while sho_day <= num_days DO
    IF start_day_out > 57 then
      start_day_out := start_day_out - 35;
      strt_ln := strt_ln +2;
    END;
    sho_day_str := STR(sho_day);
    IF length (sho_day_str) = 1 then
      sho_day_str := ' ' + sho_day_str;
    END;
    write(sho_day_str,start_day_out,strt_ln,lightgray,white);
    sho_day := sho_day + 1;
    start_day_out := start_day_out + 5;
  END;

SWITCH:
  Read_key;
    IF Key1 = 0 THEN
      Key_code := Key2;
      IF Key_code = 77 then
        mon_num := mon_num + 1;
        IF mon_num = 13 then
          mon_num := 1;
          short_yr := short_yr +1;
          long_yr := long_yr + 1;
        END;
        GOTO BEGIN_TO;
      END;
      IF Key_code = 75 then
        mon_num := mon_num - 1;
        IF mon_num = 0 then
          mon_num := 12;
          short_yr := short_yr -1;
          long_yr := long_yr - 1;
        END;
        GOTO BEGIN_TO;
      END;
      IF Key_code = 72 then
        short_yr := short_yr + 1;
        long_yr := long_yr + 1;
        GOTO BEGIN_TO;
      END;
      IF Key_code = 80 then
        short_yr := short_yr - 1;
        long_yr := long_yr - 1;
        GOTO BEGIN_TO;
      END;
      IF Key_code = 73 then
        short_yr := short_yr + 5;
        long_yr := long_yr + 5;
        GOTO BEGIN_TO;
      END;
      IF Key_code = 81 then
        short_yr := short_yr - 5;
        long_yr := long_yr - 5;
        GOTO BEGIN_TO;
      END;
      IF Key_code = 79 then
        mon_num := mon_num + 1;
        GOTO FINI;
      END;
    else
      if key1 = 27 then
        mon_num := mon_num + 1;
        GOTO FINI;
      END;
    end;
    GOTO SWITCH;

FINI:
  Kill_box;
end_of_mac:
end_macro;

{ ---------------------------------------------------------------------------- }

$macro ansi dump;

  def_str(clr_top, clr_str, clr_bot, clr_key, clr_kod, ans_def);
  def_int(clr_bak, clr_num, clr_col, clr_row, clr_for);
  def_int(flop, key_code);

  clr_top := '  30  34  32  36  31  35  33  37 ';
  clr_bot := 'Ų════════════════════════════════════╣';
  clr_kod := '    Color Sequence =  [0;3?;4?m';
  clr_key := ' [PgUp]    [PgDn]    [End]';

  flop := 0;

  put_box(39,4,78,18,lightgray,back_color,' ANSI Color Chart ',TRUE);
  write(clr_top,42,5,lightgray,back_color);
  write(clr_bot,39,14,lightgray,back_color);
  write(clr_kod,40,15,lightgray,back_color);
  write(clr_key,43,16,lightgray,back_color);
  clr_num := 40;
  clr_col := 40;
  clr_row :=  6;
  write('40',40,6,lightgray,back_color);
  write('44',40,7,lightgray,back_color);
  write('42',40,8,lightgray,back_color);
  write('46',40,9,lightgray,back_color);
  write('41',40,10,lightgray,back_color);
  write('45',40,11,lightgray,back_color);
  write('43',40,12,lightgray,back_color);
  write('47',40,13,lightgray,back_color);
  GOTO NO_FLASH;

IN_KEY:
  Read_key;
    If Key1 = 27 Then                             {Esc to Quit}
      GOTO FINI;
    END;
    IF Key1 = 0 THEN
      Key_code := Key2;
      IF Key_code = 79 then                       {END to Quit}
        GOTO FINI;
      END;
      IF Key_code = 73 then                       {PG UP other screens}
        flop := flop - 1;
      END;
      IF Key_code = 81 then                       {PG DN other screens}
        flop := flop + 1;
      END;
      IF flop = 4 Then
        flop := 0;
      END;
      IF flop = -1 Then
        flop := 3;
      END;
      IF flop = 0 Then
        ans_def := '0;3?;4?m  ';
        write(ans_def,64,15,lightgray,back_color);
        GOTO NO_FLASH;
      END;
      IF flop = 1 Then
        ans_def := '0;3?;4?;5m ';
        write(ans_def,64,15,lightgray,back_color);
        GOTO FLASH;
      END;
      IF flop = 2 Then
        ans_def := '1;3?;4?m   ';
        write(ans_def,64,15,lightgray,back_color);
        GOTO NO_FLASH_BOLD;
      END;
      IF flop = 3 Then
        ans_def := '1;3?;4?;5m';
        write(ans_def,64,15,lightgray,back_color);
        GOTO FLASH_BOLD;
      END;
    END;
    GOTO IN_KEY;

NO_FLASH:
  clr_col := 43;
  clr_row :=  6;
  clr_num := 30;
  clr_bak :=  0;
  clr_for :=  0;
  While clr_row < 14 DO
      clr_str := '  ';
      write(clr_str,clr_col,clr_row,clr_bak,clr_for);
      clr_num := clr_num +1;
      clr_for := clr_for +1;
      clr_col := clr_col + 4;
      IF clr_col > 73 Then
        clr_col := 43;
        clr_row := clr_row + 1;
        clr_for := 0;
        clr_bak := clr_bak + 1;
        clr_num := 30;
      END;
  END;
  GOTO IN_KEY;

NO_FLASH_Bold:
  clr_col := 43;
  clr_row :=  6;
  clr_num := 30;
  clr_bak :=  0;
  clr_for :=  8;
  While clr_row < 14 DO
      clr_str := '  ';
      write(clr_str,clr_col,clr_row,clr_bak,clr_for);
      clr_num := clr_num +1;
      clr_for := clr_for +1;
      clr_col := clr_col + 4;
      IF clr_col > 73 Then
        clr_col := 43;
        clr_row := clr_row + 1;
        clr_for := 8;
        clr_bak := clr_bak + 1;
        clr_num := 30;
      END;
  END;
  GOTO IN_KEY;

FLASH:
  clr_col := 43;
  clr_row :=  6;
  clr_bak :=  0;
  clr_for := 128;

  While clr_row < 14 DO
      clr_str := '  ';
      write(clr_str,clr_col,clr_row,clr_bak,clr_for);
      clr_num := clr_num +1;
      clr_for := clr_for +1;
      clr_col := clr_col + 4;
      IF clr_col > 73 Then
        clr_col := 43;
        clr_row := clr_row + 1;
        clr_for := 128;
        clr_bak := clr_bak + 1;
        clr_num := 30;
      END;
  END;
  GOTO IN_KEY;

FLASH_BOLD:
  clr_col := 43;
  clr_row :=  6;
  clr_bak :=  0;
  clr_for := 136;

  While clr_row < 14 DO
      clr_str := '  ';
      write(clr_str,clr_col,clr_row,clr_bak,clr_for);
      clr_num := clr_num +1;
      clr_for := clr_for +1;
      clr_col := clr_col + 4;
      IF clr_col > 73 Then
        clr_col := 43;
        clr_row := clr_row + 1;
        clr_for := 136;
        clr_bak := clr_bak + 1;
        clr_num := 30;
      END;
  END;
  GOTO IN_KEY;

FINI:
  Kill_box;
end_of_mac:
end_macro;

{******************************************************************************}
{                                MULTI-EDIT MACRO                              }
{                                                                              }
{Name: CGA                                   Timestamp: 06/04/88 02:46pm       }
{                                                                              }
{Description: Shows CGA color chart          Contributed by Dick Botbyl        }
{                                                                              }
{******************************************************************************}

$macro cga dump;

  def_str(clr_str, clr_bot, clr_key);
  def_int(clr_bak, clr_num, clr_col, clr_row, clr_for);
  def_int(flop, key_code);
                                         { Initialize variables }

  clr_bot := 'Ų════════════════════════════════╣';
  clr_key := '│    [PgUp]    [PgDn]    [End]';

  flop := 0;

  put_box(43,4,78,24,lightgray,back_color,' Color Chart ',true);
  write(clr_bot,43,21,lightgray,back_color);
  write(clr_key,43,22,lightgray,back_color);
  GOTO NO_FLASH;

IN_KEY:
  Read_key;
    IF Key1 = 0 THEN
      Key_code := Key2;
      IF (Key_code = 79) or (key_code = 27) then
        GOTO FINI;
      END;
      IF Key_code = 73 then
        flop := flop + 1;
      END;
      IF Key_code = 81 then
        flop := flop + 1;
      END;
      IF flop = 2 Then
        flop := 0;
      END;
      IF flop = 0 Then
        GOTO NO_FLASH;
      END;
      IF flop = 1 Then
        GOTO FLASH;
      END;
    END;
    GOTO IN_KEY;

NO_FLASH:
  clr_col := 44;
  clr_row :=  5;
  clr_num :=  0;
  clr_bak :=  0;
  clr_for :=  0;
  While clr_num < 128 DO
    clr_str := STR(clr_num);
      IF clr_num < 10 then
        clr_str := '  ' + clr_str + ' ';
      END;
      IF clr_num > 9 then
        IF clr_num > 99 Then
          clr_str := clr_str + ' ';
        ELSE
          clr_str := ' ' + clr_str + ' ';
        END;
      END;
    write(clr_str,clr_col,clr_row,clr_bak,clr_for);
    clr_num := clr_num +1;
    clr_for := clr_for +1;
    clr_col := clr_col + 4;
      IF clr_col > 73 Then
        clr_col := 44;
        clr_row := clr_row + 1;
      END;
      IF clr_col > 73 Then
        IF clr_for = 32 Then
          clr_bak := clr_bak + 1;
          clr_for :=  0;
        END;
      END;
  END;
  GOTO IN_KEY;

FLASH:
  clr_col := 44;
  clr_row :=  5;
  clr_bak :=  0;
  While clr_num < 256 DO
    If clr_num < 128 Then
      clr_num := 128;
    END;
    clr_str := STR(clr_num);
    clr_str := clr_str + ' ';
    write(clr_str,clr_col,clr_row,clr_bak,clr_for);
    clr_num := clr_num +1;
    clr_for := clr_for +1;
    clr_col := clr_col + 4;
      IF clr_col > 73 Then
        clr_col := 44;
        clr_row := clr_row + 1;
      END;
      IF clr_col > 73 Then
        IF clr_for = 64 Then
          clr_bak := clr_bak + 1;
          clr_for := 32;
        END;
      END;
  END;
  GOTO IN_KEY;


FINI:
  Kill_box;
end_of_mac:
end_macro;