{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Synchronisation",
			"type": "node-terminal",
			"request": "launch",
			"command": "make Synchronisation",
			"cwd": "${workspaceFolder}"
		},
		{
			"name": "Debug mr (GDB)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/mr",
			"args": [],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"externalConsole": false,
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			],
			"preLaunchTask": "Rebuild mr (Clean & Neu)"
		},
		{
			"name": "Debug mr (LLDB)",
			"type": "lldb",
			"request": "launch",
			"program": "${workspaceFolder}/mr",
			"args": [],
			"cwd": "${workspaceFolder}",
			"preLaunchTask": "Rebuild mr (Clean & Neu)"
		}
	]
}
